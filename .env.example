# ============================================
# Configuration du système de surveillance par drone
# ============================================

# --- Environnement ---
ENVIRONMENT=development
COMPOSE_PROJECT_NAME=ai-drone-surveillance

# --- MediaMTX (Ingestion vidéo) ---
MEDIAMTX_PORT=8888
MEDIAMTX_RTSP_PORT=8554
MEDIAMTX_RTMP_PORT=1935
MEDIAMTX_SRT_PORT=6000
MEDIAMTX_HLS_PORT=8888

# --- Redis (Bus de messages) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CHANNEL=alerts

# --- PostgreSQL (Base de données) ---
POSTGRES_PORT=5432
POSTGRES_DB=drone_surveillance
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- FastAPI (Backend) ---
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0
SECRET_KEY=change_me_in_production_use_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Frontend (Dashboard) ---
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/alerts

# --- IA Pipeline ---
INFERENCE_DEVICE=cuda  # Options: cuda, cpu, mps
MODEL_PATH=/models/yolov8n.pt
MODEL_CONFIDENCE_THRESHOLD=0.5
SAHI_SLICE_HEIGHT=512
SAHI_SLICE_WIDTH=512
SAHI_OVERLAP_RATIO=0.2

# --- Tracking ---
TRACKING_BUFFER_SIZE=30
TRACKING_MAX_AGE=30

# --- Zones et règles ---
CROWD_THRESHOLD=5
CROWD_DURATION_SECONDS=30
MOVEMENT_SPEED_THRESHOLD_PX_PER_SEC=50

# --- Stockage médias ---
MEDIA_STORAGE_PATH=/media/snapshots
CLIP_STORAGE_PATH=/media/clips
SNAPSHOT_RETENTION_DAYS=30
CLIP_RETENTION_DAYS=7

# --- Nginx (Reverse proxy) ---
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# --- Monitoring (optionnel) ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
